DATABASE_URL=postgresql://postgres:password@localhost:5432/safety_db

# Model paths — replace with paths to your trained PPE/pose models
PPE_MODEL_PATH=yolov8n.pt
POSE_MODEL_PATH=yolov8n-pose.pt
PERSON_MODEL_PATH=yolov8n.pt

# Detection thresholds (0.0 - 1.0)
PPE_CONFIDENCE=0.5
ZONE_CONFIDENCE=0.5
FALL_CONFIDENCE=0.5

# Seconds a person must be motionless before a fall alert is raised
MOTIONLESS_SECONDS=60

# Minimum seconds between repeat alerts for the same camera/event type
ALERT_COOLDOWN_SECONDS=30

# Process every Nth frame from the stream (reduces CPU load)
FRAME_SKIP=5

# Directory where alert snapshot images are saved
ALERT_IMAGE_DIR=alert_images
